{{!
    @template mod_projetvet/reportbuilder/student_checkbox

    Student selection checkbox for reportbuilder.

    Context variables required for this template:
    * studentid - The user ID of the student

    Example context (json):
    {
        "studentid": 123
    }
}}
<div class="custom-control custom-checkbox">
    <input class="custom-control-input student-select-checkbox" type="checkbox" id="student-checkbox-{{studentid}}" data-action="select-student" data-studentid="{{studentid}}">
    <label class="custom-control-label" for="student-checkbox-{{studentid}}"></label>
</div>
