{{!
    @template mod_projetvet/reportbuilder/teacher_radio

    Teacher selection radio button for reportbuilder.

    Context variables required for this template:
    * teacherid - The user ID of the teacher

    Example context (json):
    {
        "teacherid": 123
    }
}}
<div class="custom-control custom-radio">
    <input class="custom-control-input teacher-select-radio" type="radio" name="teacher-select" id="teacher-radio-{{teacherid}}" data-action="select-teacher" data-teacherid="{{teacherid}}">
    <label class="custom-control-label" for="teacher-radio-{{teacherid}}"></label>
</div>
