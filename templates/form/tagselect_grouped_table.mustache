{{!
    @template mod_projetvet/form/tagselect_grouped_table

    Displays selected tags organized by groups in a table format.

    Context variables required for this template:
    * selectedgroups - Array of groups with items
        * heading - Group name
        * items - Array of tag items
            * tagid - Tag ID
            * tagname - Tag name
            * action - Action identifier (e.g., 'remove-tag')

    Example context (json):
    {
        "selectedgroups": [
            {
                "heading": "Group 1",
                "items": [
                    {"tagid": "1", "tagname": "Item 1", "action": "remove-tag"},
                    {"tagid": "2", "tagname": "Item 2", "action": "remove-tag"}
                ]
            }
        ]
    }
}}
<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>{{#str}}competency, mod_projetvet{{/str}}</th>
            <th class="text-center">{{#str}}actions{{/str}}</th>
        </tr>
    </thead>
    <tbody>
        {{#selectedgroups}}
        <tr class="table-active">
            <td colspan="2"><strong>{{{heading}}}</strong></td>
        </tr>
        {{#items}}
        <tr data-tag-id="{{tagid}}">
            <td>{{tagname}}</td>
            <td class="text-center">
                <button type="button"
                        class="btn btn-sm btn-link p-0"
                        data-action="{{action}}"
                        data-tag-id="{{tagid}}"
                        aria-label="{{#str}}remove{{/str}}">
                    {{#pix}}t/delete, core{{/pix}}
                </button>
            </td>
        </tr>
        {{/items}}
        {{/selectedgroups}}
    </tbody>
</table>
