{{!
    @template mod_projetvet/admin_page

    Admin page template with student and teacher reports.

    Context variables required for this template:
    * cmid - Course module ID
    * projetvetid - Projetvet instance ID
    * studentstoggle - Toggle context for filtering students
    * studentsreport - The students report HTML
    * teacherstoggle - Toggle context for filtering teachers
    * teachersreport - The teachers report HTML

    Example context (json):
    {
        "cmid": 123,
        "projetvetid": 456,
        "studentstoggle": {
            "id": "filter-students-without-teacher",
            "checked": true,
            "label": "Show only students without teachers",
            "dataattributes": []
        },
        "studentsreport": "<div>...</div>",
        "teacherstoggle": {
            "id": "filter-teachers-with-capacity",
            "checked": false,
            "label": "Show only teachers with capacity",
            "dataattributes": []
        },
        "teachersreport": "<div>...</div>"
    }
}}
<div class="d-flex align-items-center mb-3 position-relative">
    {{< mod_projetvet/expandcollapse }}
        {{$id}}students-section{{/id}}
    {{/ mod_projetvet/expandcollapse }}
    <h3 class="mb-0">{{#str}}admin_students_heading, mod_projetvet{{/str}}</h3>
</div>

<div class="collapse show" id="collapsestudents-section">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            {{#studentstoggle}}
                {{> core/toggle }}
            {{/studentstoggle}}
        </div>
        <div>
            <button type="button" class="btn btn-primary d-none" id="assign-selected-students" data-action="assign-teacher" data-projetvetid="{{projetvetid}}" data-cmid="{{cmid}}">
                {{#str}}assignteacher, mod_projetvet{{/str}}
            </button>
        </div>
    </div>

    <div id="students-report-container">
        {{{studentsreport}}}
    </div>
</div>

<br>
<br>

<div class="d-flex align-items-center mb-3 position-relative">
    {{< mod_projetvet/expandcollapse }}
        {{$id}}teachers-section{{/id}}
    {{/ mod_projetvet/expandcollapse }}
    <h3 class="mb-0">{{#str}}admin_teachers_heading, mod_projetvet{{/str}}</h3>
</div>

<div class="collapse show" id="collapseteachers-section">
    {{#teacherstoggle}}
        {{> core/toggle }}
    {{/teacherstoggle}}

    <br>

    <div id="teachers-report-container">
        {{{teachersreport}}}
    </div>
</div>

{{#js}}
require(['mod_projetvet/clickable_rows', 'mod_projetvet/manage_groups', 'mod_projetvet/admin_filters'], function(clickableRows, manageGroups, adminFilters) {
    clickableRows.init();
    manageGroups.init();
    adminFilters.init();
});
{{/js}}
